# Base de datos local (docker-compose)
DB_ENDPOINT=mysql
DB_PORT=3306
DB_NAME=despacho_db
DB_USERNAME=despacho_user
DB_PASSWORD=despacho_pass
MYSQL_ROOT_PASSWORD=rootpass

# Frontend (build time)
VITE_VENTAS_API_URL=/api/v1/ventas
VITE_DESPACHOS_API_URL=/api/v1/despachos

# AWS (Learner Lab - credenciales temporales STS)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# EKS
EKS_CLUSTER_NAME=despacho-eks
EKS_NAMESPACE=despacho
